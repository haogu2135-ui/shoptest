{
  "name": "shop-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ant-design/icons": "^5.0.1",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.11",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "antd": "^5.0.0",
    "axios": "^1.3.0",
    "dompurify": "^3.4.8",
    "province-city-china": "^8.5.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "serve:build": "node scripts/serve-build.js",
    "prebuild": "node scripts/generate-mobile-version.js",
    "build": "GENERATE_SOURCEMAP=false react-scripts build",
    "postbuild": "node scripts/restore-build-ownership.js",
    "analyze:bundle": "node scripts/analyze-bundle.js",
    "build:analyze": "npm run build && npm run analyze:bundle",
    "check:bundle": "BUNDLE_ANALYZE_ENFORCE=true node scripts/analyze-bundle.js",
    "test:bundle-analyzer": "node scripts/analyze-bundle.test.js",
    "test:antd-tree-shaking": "node scripts/antd-tree-shaking.test.js",
    "test": "react-scripts test --watchAll=false",
    "test:jest-config": "node scripts/jest-transform-config.test.js",
    "eject": "react-scripts eject",
    "test:commercial-smoke": "node scripts/commercial-http-smoke.js",
    "test:commercial-browser-smoke": "node scripts/commercial-browser-smoke.js"
  },
  "overrides": {
    "@adobe/css-tools": "4.0.0"
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!(@adobe/css-tools|@testing-library)/)"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  },
  "proxy": "http://127.0.0.1:8081"
}
