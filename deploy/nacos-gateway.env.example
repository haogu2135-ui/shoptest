# Compose-level values for deploy/docker-compose.nacos-gateway.yml.
# Application runtime secrets belong in backend.env or gateway.env.
NACOS_BIND_IP=127.0.0.1
NACOS_AUTH_TOKEN=replace-with-nacos-auth-token-at-least-32-bytes
NACOS_AUTH_IDENTITY_KEY=replace-with-nacos-identity-key
NACOS_AUTH_IDENTITY_VALUE=replace-with-nacos-identity-value
BACKEND_BIND_IP=127.0.0.1
BACKEND_HOST_PORT=8081
GATEWAY_BIND_IP=127.0.0.1
GATEWAY_HOST_PORT=8080
