
# Cloudflare connecting-IP restoration for access logs, rate limits, webhook evidence.
# Keep ranges in sync with https://www.cloudflare.com/ips/ when Cloudflare updates them.
set_real_ip_from 173.245.48.0/20;
set_real_ip_from 103.21.244.0/22;
set_real_ip_from 103.22.200.0/22;
set_real_ip_from 103.31.4.0/22;
set_real_ip_from 141.101.64.0/18;
set_real_ip_from 108.162.192.0/18;
set_real_ip_from 190.93.240.0/20;
set_real_ip_from 188.114.96.0/20;
set_real_ip_from 197.234.240.0/22;
set_real_ip_from 198.41.128.0/17;
set_real_ip_from 162.158.0.0/15;
set_real_ip_from 104.16.0.0/13;
set_real_ip_from 104.24.0.0/14;
set_real_ip_from 172.64.0.0/13;
set_real_ip_from 131.0.72.0/22;
set_real_ip_from 2400:cb00::/32;
set_real_ip_from 2606:4700::/32;
set_real_ip_from 2803:f800::/32;
set_real_ip_from 2405:b500::/32;
set_real_ip_from 2405:8100::/32;
set_real_ip_from 2a06:98c0::/29;
set_real_ip_from 2c0f:f248::/32;
real_ip_header CF-Connecting-IP;
real_ip_recursive on;

# Ensure CSP connect-src is always initialized (avoids nginx warn on odd Host paths).
map $host $shop_csp_connect_src {
    default "'self' https://cloudflareinsights.com wss://$host ${CSP_EXTRA_CONNECT_SRC}";
}

# Commercial edge: serve HTTP content (no force-HTTPS redirect).
# Cloudflare Flexible SSL proxies client HTTPS -> origin HTTP. A 301 to HTTPS here
# creates a CF edge loop and hangs public requests. Full/Strict still use :443 below.
server {
    listen 80;
    server_name ${CANONICAL_REDIRECT_NAMES};

    location = /healthz {
        access_log off;
        add_header Cache-Control "no-store" always;
        return 204;
    }

    location / {
        return 301 http://${CANONICAL_SERVER_NAME}$request_uri;
    }
}

server {
    # default_server: unknown Host / bare-IP probes still serve the storefront so Cloudflare
    # origin health checks and mis-set Host headers do not 301-loop into 521/522.
    listen 80 default_server;
    server_name ${CANONICAL_SERVER_NAME} _;

    root /usr/share/nginx/html;
    index index.html;
    client_max_body_size ${CLIENT_MAX_BODY_SIZE};

    gzip on;
    gzip_comp_level 5;
    gzip_min_length 1024;
    gzip_vary on;
    gzip_types
        application/javascript
        application/json
        application/xml
        image/svg+xml
        text/css
        text/javascript
        text/plain
        text/xml;

    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
    set $shop_csp_connect_src "'self' https://cloudflareinsights.com wss://$host ${CSP_EXTRA_CONNECT_SRC}";
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src $shop_csp_connect_src; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;

    location = /healthz {
        access_log off;
        add_header Cache-Control "no-store" always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
        return 204;
    }

    if ($request_uri ~* "(?:^|/)(?:\.\.|%2e%2e)(?:/|$)") {
        return 400;
    }



    location = /.well-known/security.txt {
        default_type text/plain;
        add_header Cache-Control "public, max-age=86400" always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
        add_header Content-Security-Policy "default-src 'none'; frame-ancestors 'none'; base-uri 'none'" always;
        try_files /.well-known/security.txt =404;
    }

    location ^~ /.well-known/acme-challenge/ {
        default_type "text/plain";
        # Writable certbot webroot (static build is mounted read-only).
        root /var/www/certbot;
        try_files $uri =404;
    }

    # SPA shell must never be long-cached: hashed JS/CSS are immutable, HTML is the pointer.

    # Dynamic commercial sitemap (marketing + public product detail URLs) from backend.
    location = /sitemap.xml {
        proxy_pass ${BACKEND_ORIGIN}/sitemap.xml;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        # Upstream already sets commercial headers; hide them so location add_header is single-valued.
        proxy_hide_header Cache-Control;
        proxy_hide_header X-Frame-Options;
        proxy_hide_header X-Content-Type-Options;
        proxy_hide_header Referrer-Policy;
        proxy_hide_header Permissions-Policy;
        proxy_hide_header Content-Security-Policy;
        proxy_hide_header Strict-Transport-Security;
        set $forwarded_proto $scheme;
        if ($http_cf_visitor ~* '"scheme":"https"') {
            set $forwarded_proto https;
        }
        if ($http_x_forwarded_proto != "") {
            set $forwarded_proto $http_x_forwarded_proto;
        }
        proxy_set_header X-Forwarded-Proto $forwarded_proto;
        proxy_connect_timeout 5s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;
        add_header Cache-Control "public, max-age=300" always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
        add_header Content-Security-Policy "default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src $shop_csp_connect_src; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
    }

    # Note: any location-level add_header suppresses parent server add_header inheritance in nginx.
    location = /index.html {
        add_header Cache-Control "no-store, no-cache, must-revalidate" always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
        add_header Content-Security-Policy "default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src $shop_csp_connect_src; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
        try_files /index.html =404;
    }

    location = / {
        add_header Cache-Control "no-store, no-cache, must-revalidate" always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
        add_header Content-Security-Policy "default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src $shop_csp_connect_src; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
        try_files /index.html =404;
    }

    location ~ ^/(?:products(?:/[^/]+)?|pet-finder|pet-gallery|compare|cart|checkout|coupons|profile|wishlist|history|stock-alerts|notifications|track-order|payment/[^/]+|login|forgot-password|register|product-management|category-management)/?$ {
        try_files $uri /index.html;
    }

    location ~ ^/admin(?:/(?:dashboard|products|brands|categories|orders|logistics-carriers|coupons|users|permissions|reviews|questions|notifications|announcements|support|audit-logs|alerts|bugs|ip-blacklist|logs|registry|config-center|traffic-control|system|pet-gallery)(?:/.*)?)?/?$ {
        try_files $uri /index.html;
    }

    location / {
        try_files $uri @spa_not_found_http;
    }

    location @spa_not_found_http {
        internal;
        add_header Cache-Control "no-store" always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
        add_header Content-Security-Policy "default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src $shop_csp_connect_src; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
        error_page 418 =404 /index.html;
        return 418;
    }

    # CRA content-hashed assets under /static/** — stop regex .js/.css from stealing this
    # prefix match, and ship commercial long-cache immutable headers (1y).
    location ^~ /static/ {
        # Prefer a single Cache-Control (avoid expires + add_header double headers).
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
        add_header Content-Security-Policy "default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src $shop_csp_connect_src; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
        try_files $uri =404;
    }

    location ~* \.map$ {
        add_header Cache-Control "no-store" always;
        return 404;
    }

    location = /runtime-config.js {
        add_header Cache-Control "no-store, no-cache, must-revalidate" always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
        add_header Content-Security-Policy "default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src $shop_csp_connect_src; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
        try_files $uri =404;
    }


    # Non-hashed LCP hero CSS must stay revalidatable after deploys (not 30d public assets).
    location = /home-hero-vars.css {
        add_header Cache-Control "no-cache" always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
        add_header Content-Security-Policy "default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src $shop_csp_connect_src; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
        try_files $uri =404;
    }


    # Public non-hashed assets (favicon, /assets/**). Single Cache-Control only (no expires dual).
    location ~* \.(?:css|js|mjs|svg|ico|png|jpg|jpeg|gif|webp|avif|woff2?)$ {
        add_header Cache-Control "public, max-age=2592000" always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
        add_header Content-Security-Policy "default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src $shop_csp_connect_src; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" always;
        try_files $uri =404;
    }

    location /api/ {
        proxy_pass ${BACKEND_ORIGIN}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        # Preserve client scheme when behind Cloudflare Flexible (CF-Visitor / X-Forwarded-Proto).
        set $forwarded_proto $scheme;
        if ($http_cf_visitor ~* '"scheme":"https"') {
            set $forwarded_proto https;
        }
        if ($http_x_forwarded_proto != "") {
            set $forwarded_proto $http_x_forwarded_proto;
        }
        proxy_set_header X-Forwarded-Proto $forwarded_proto;
        proxy_connect_timeout 5s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    location /ws/ {
        proxy_pass ${BACKEND_ORIGIN}/ws/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        set $forwarded_proto $scheme;
        if ($http_cf_visitor ~* '"scheme":"https"') {
            set $forwarded_proto https;
        }
        if ($http_x_forwarded_proto != "") {
            set $forwarded_proto $http_x_forwarded_proto;
        }
        proxy_set_header X-Forwarded-Proto $forwarded_proto;
        proxy_read_timeout 3600s;
    }

    location ^~ /uploads/ {
        proxy_pass ${BACKEND_ORIGIN}/uploads/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        set $forwarded_proto $scheme;
        if ($http_cf_visitor ~* '"scheme":"https"') {
            set $forwarded_proto https;
        }
        if ($http_x_forwarded_proto != "") {
            set $forwarded_proto $http_x_forwarded_proto;
        }
        proxy_set_header X-Forwarded-Proto $forwarded_proto;
        proxy_connect_timeout 5s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        # Single Cache-Control only (avoid expires + add_header dual headers).
        add_header Cache-Control "public, max-age=2592000" always;
    }
}

server {
    listen ${HTTPS_LISTEN_PORT} ssl http2;
    server_name ${CANONICAL_REDIRECT_NAMES};

    ssl_certificate ${SSL_CERTIFICATE};
    ssl_certificate_key ${SSL_CERTIFICATE_KEY};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    return 301 https://${CANONICAL_SERVER_NAME}$request_uri;
}

