SERVER_NAME=pet.686888666.xyz
CANONICAL_SERVER_NAME=pet.686888666.xyz
CANONICAL_REDIRECT_NAMES=www.pet.686888666.xyz
HTTPS_LISTEN_PORT=443
SSL_CERTIFICATE=/etc/nginx/ssl/pet.686888666.xyz.crt
SSL_CERTIFICATE_KEY=/etc/nginx/ssl/pet.686888666.xyz.key
SSL_CERTIFICATE_HOST_PATH=/etc/nginx/ssl/pet.686888666.xyz.crt
SSL_CERTIFICATE_KEY_HOST_PATH=/etc/nginx/ssl/pet.686888666.xyz.key
# The certificate used here must include both pet.686888666.xyz and
# www.pet.686888666.xyz in subjectAltName when CANONICAL_REDIRECT_NAMES
# contains the www host; TLS validation happens before the 301 redirect.
# Static frontend proxies /api, /ws, and /uploads to the backend service.
# Use the internal backend or gateway origin that the edge container can reach.
BACKEND_ORIGIN=http://backend.internal.example:8081
CLIENT_MAX_BODY_SIZE=6m
