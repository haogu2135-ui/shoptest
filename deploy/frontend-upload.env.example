# Copy this file to deploy/frontend-upload.local.env and fill in your server info.
# The .local.env file is ignored by git, so do not put real secrets in this example.

DEPLOY_HOST=your.server.public.ip
DEPLOY_USER=root
DEPLOY_PASSWORD=replace-with-server-password
DEPLOY_PORT=22
DEPLOY_TARGET=/var/www/shoptest/

# Keep these defaults unless you know you need to change them.
RSYNC_OPTIONS=-av --delete
SSH_EXTRA_OPTIONS=-o StrictHostKeyChecking=accept-new
