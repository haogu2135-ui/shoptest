# Copy this file to deploy/backend-upload.local.env and fill in your backend server info.
# The .local.env file is ignored by git. Do not put real passwords in this example file.
BACKEND_DEPLOY_HOST=your.backend.server.public.ip
BACKEND_DEPLOY_USER=root
BACKEND_DEPLOY_PASSWORD=replace-with-backend-server-password
BACKEND_DEPLOY_PORT=22

# The backend server is separate from the frontend server.
# The jar is uploaded here and then systemd restarts the backend service.
BACKEND_DEPLOY_TARGET_DIR=/opt/shoptest
BACKEND_DEPLOY_SERVICE=shoptest-backend
BACKEND_REMOTE_TEMP_DIR=/tmp/shoptest-backend-deploy
BACKEND_JAR_NAME=shop.jar

# Optional. Leave blank if the jar only needs to be readable by the service user.
BACKEND_DEPLOY_OWNER=

# Optional remote health check run on the backend server after restart.
# Example: http://127.0.0.1:8081/app/config
BACKEND_HEALTHCHECK_URL=

MAVEN_ARGS=-DskipTests package
RSYNC_OPTIONS=-az --delay-updates
SSH_EXTRA_OPTIONS=-o StrictHostKeyChecking=accept-new
